APP_NAME="AI Interview Analysis Platform"
ENVIRONMENT=development

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=interview_growth_platform

JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_PASSWORD_RESET_EXPIRE_MINUTES=15

# Optional but recommended for protected admin-only setup endpoints.
ADMIN_SYNC_TOKEN=change-this-admin-token

# Optional default sheet source for /students/import-sheet.
STUDENT_SHEET_URL=https://docs.google.com/spreadsheets/d/1d8y0mhkdhgaphjX3Onxd2DHECiYw2rJYfSQmMyWZOcg/edit?usp=sharing
